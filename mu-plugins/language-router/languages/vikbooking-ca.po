msgstr "Enviar sol.licitud"

#: site/mod_vikbooking_horizontalsearch:INQ_CHECK_AVAILABILITY
msgid "Check availability"
msgstr "Comprovar disponibilitat"

#: site/mod_vikbooking_horizontalsearch:INQ_NOTES_SPREQUESTS
msgid "Notes/Special requests"
msgstr "Notes/Peticions especials"

#: site/mod_vikbooking_horizontalsearch:INQ_OR_BOOK_ONLINE
msgid "or book online"
msgstr "o reservar en línia"

#: site/mod_vikbooking_horizontalsearch:VBO_PLEASE_FILL_FIELDS
