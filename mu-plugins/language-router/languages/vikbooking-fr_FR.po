#: admin/com_vikbooking:VBO_W_STICKYN_HELP_TITLE
msgid "Notes text formatting"
msgstr "Formatage du texte des notes"

#: admin/com_vikbooking:VBO_W_STICKYN_HELP_DESCR
msgid "You can use the following keyboard shortcuts while typing the text of your note:<br/><br/><b>Ctrl + B</b>: makes the text selection bold.<br/><b>Ctrl + I</b>: makes the text selection italic.<br/><b>Ctrl + U</b>: underlines the text selection.<br/><b>Ctrl + S</b>: strike-through the text selection.<br/><b>Ctrl + H/T</b>: makes the current block a title/heading.<br/><b>Ctrl + P</b>: makes the current block a paragraph.<br/><b>Ctrl + L</b>: adds a new bullet list, or converts the text selection to a link.<br/><b>Ctrl + O/N</b>: adds a new numbered list.<br/><b>Ctrl + A</b>: makes the whole text selected.<br/><b>Ctrl + M</b>: converts the markup text selection to HTML."
msgstr "Vous pouvez utiliser les raccourcis clavier suivants lors de la saisie du texte de votre note :<br/><br/><b>Ctrl + B</b> : met la sélection de texte en gras.<br/><b>Ctrl + I </b> : met la sélection de texte en italique.<br/><b>Ctrl + U</b> : souligne la sélection de texte.<br/><b>Ctrl + S</b> : barre le sélection de texte.<br/><b>Ctrl + H/T</b> : transforme le bloc actuel en titre/en-tête.<br/><b>Ctrl + P</b> : transforme le bloc actuel en paragraphe .<br/><b>Ctrl + L</b> : ajoute une nouvelle liste à puces ou convertit la sélection de texte en lien.<br/><b>Ctrl + O/N</b> : ajoute un nouvelle liste numérotée.<br/><b>Ctrl + A</b> : sélectionne tout le texte.<br/><b>Ctrl + M</b> : convertit la sélection de texte de balisage en HTML."

#: admin/com_vikbooking:VBO_W_STICKYN_HELP_DESCR_MAC
msgid "You can use the following keyboard shortcuts while typing the text of your note:<br/><br/><b>&#8984; + B</b>: makes the text selection bold.<br/><b>&#8984; + I</b>: makes the text selection italic.<br/><b>&#8984; + U</b>: underlines the text selection.<br/><b>&#8984; + S</b>: strike-through the text selection.<br/><b>&#8984; + H/T</b>: makes the current block a title/heading.<br/><b>&#8984; + P</b>: makes the current block a paragraph.<br/><b>&#8984; + L</b>: adds a new bullet list, or converts the text selection to a link.<br/><b>&#8984; + O/N</b>: adds a new numbered list.<br/><b>&#8984; + A</b>: makes the whole text selected.<br/><b>Ctrl + M</b>: converts the markup text selection to HTML.<br/><br/>Some commands may also be executed by holding <kbd>Ctrl</kbd> rather than <kbd>&#8984;</kbd>."
msgstr "Vous pouvez utiliser les raccourcis clavier suivants lors de la saisie du texte de votre note :<br/><br/><b>⌘ + B</b> : met la sélection de texte en gras.<br/><b>⌘ + I</b> : met la sélection de texte en italique.<br/><b>⌘ + U</b> : souligne la sélection de texte.<br/><b>⌘ + S</b> : barrer la sélection de texte.<br/><b>⌘ + H/T</b> : fait du bloc actuel un titre/en-tête.<br/><b>⌘ + P</b> : transforme le bloc actuel en paragraphe.<br/><b>⌘ + L</b> : ajoute une nouvelle liste à puces ou convertit la sélection de texte en lien.<br/><b>⌘ + O/N</b> : ajoute une nouvelle liste numérotée.<br/><b>⌘ + A</b> : sélectionne tout le texte.<br/><b>Ctrl + M</b> : convertit la sélection de texte de balisage en HTML.<br/><br/>Certaines commandes peuvent également être exécutées en maintenant <kbd>Ctrl</kbd> plutôt que <kbd>⌘</kbd>."

